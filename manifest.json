{
  "manifest_version": 3,
  "name": "MakerWorld Instant STL Extractor",
  "version": "1.0",
  "description": "Intercepts MakerWorld zip downloads and delivers raw STLs directly.",
  "permissions": [
    "downloads",
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://makerworld.com/*",
    "*://*.makerworld.com/*",
    "*://bblmw.com/*",
    "*://*.bblmw.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MakerWorld STL Extractor"
  },
  "background": {
    "service_worker": "background.js"
  }
}